# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin credentials (server-only). ADMIN_PASSWORD is plaintext config; only used
# server-side. For production, set these in Vercel project Environment Variables.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Random 32+ char string used to sign the admin session cookie (HMAC).
ADMIN_SESSION_SECRET=

# Optional: public site URL used by scripts/crawl-public-posts.js
LEGACY_PUBLIC_SITE=https://www.mercury.or.kr
